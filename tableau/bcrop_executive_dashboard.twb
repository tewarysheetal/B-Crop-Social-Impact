          <alias key='&quot;[federated.08qekmk1t77db116ouqrp1pc2tm0].[avg:impact_area_workers:qk]&quot;' value='Workers' />
        </aliases>
      </column>
      <column caption='Top Impact Area' datatype='string' name='[Calculation_2606989963350017]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ZN([impact_area_community]) &gt;= ZN([impact_area_customers])&#13;&#10;AND ZN([impact_area_community]) &gt;= ZN([impact_area_environment])&#13;&#10;AND ZN([impact_area_community]) &gt;= ZN([impact_area_governance])&#13;&#10;AND ZN([impact_area_community]) &gt;= ZN([impact_area_workers])&#13;&#10;THEN &quot;Community&quot;&#13;&#10;&#13;&#10;ELSEIF ZN([impact_area_customers]) &gt;= ZN([impact_area_community])&#13;&#10;AND ZN([impact_area_customers]) &gt;= ZN([impact_area_environment])&#13;&#10;AND ZN([impact_area_customers]) &gt;= ZN([impact_area_governance])&#13;&#10;AND ZN([impact_area_customers]) &gt;= ZN([impact_area_workers])&#13;&#10;THEN &quot;Customers&quot;&#13;&#10;&#13;&#10;ELSEIF ZN([impact_area_environment]) &gt;= ZN([impact_area_community])&#13;&#10;AND ZN([impact_area_environment]) &gt;= ZN([impact_area_customers])&#13;&#10;AND ZN([impact_area_environment]) &gt;= ZN([impact_area_governance])&#13;&#10;AND ZN([impact_area_environment]) &gt;= ZN([impact_area_workers])&#13;&#10;THEN &quot;Environment&quot;&#13;&#10;&#13;&#10;ELSEIF ZN([impact_area_governance]) &gt;= ZN([impact_area_community])&#13;&#10;AND ZN([impact_area_governance]) &gt;= ZN([impact_area_customers])&#13;&#10;AND ZN([impact_area_governance]) &gt;= ZN([impact_area_environment])&#13;&#10;AND ZN([impact_area_governance]) &gt;= ZN([impact_area_workers])&#13;&#10;THEN &quot;Governance&quot;&#13;&#10;&#13;&#10;ELSEIF ZN([impact_area_workers]) &gt;= ZN([impact_area_community])&#13;&#10;AND ZN([impact_area_workers]) &gt;= ZN([impact_area_customers])&#13;&#10;AND ZN([impact_area_workers]) &gt;= ZN([impact_area_environment])&#13;&#10;AND ZN([impact_area_workers]) &gt;= ZN([impact_area_governance])&#13;&#10;THEN &quot;Workers&quot;&#13;&#10;&#13;&#10;ELSE &quot;Missing/Unknown&quot;&#13;&#10;END' />
      </column>
      <column caption='Certification Age Group' datatype='string' name='[Calculation_2606989965500418]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [years_since_first_certification] &lt; 3 THEN &quot;0-2 years&quot;&#13;&#10;ELSEIF [years_since_first_certification] &lt; 6 THEN &quot;3-5 years&quot;&#13;&#10;ELSEIF [years_since_first_certification] &lt; 10 THEN &quot;6-9 years&quot;&#13;&#10;ELSE &quot;10+ years&quot;&#13;&#10;END' />
      </column>
      <column caption='Score Above Threshold' datatype='real' name='[Calculation_2606989966938115]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[overall_score] - 80' />
      </column>
      <column caption='Selected Metric Value' datatype='real' name='[Calculation_2606989969367045]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;Community&quot; THEN [impact_area_community]&#13;&#10;WHEN &quot;Customers&quot; THEN [impact_area_customers]&#13;&#10;WHEN &quot;Environment&quot; THEN [impact_area_environment]&#13;&#10;WHEN &quot;Governance&quot; THEN [impact_area_governance]&#13;&#10;WHEN &quot;Workers&quot; THEN [impact_area_workers]&#13;&#10;END' />
      </column>
