    <worksheet name='Score Above Threshold/Industry'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#5c2075' fontsize='10'>Industry Score Above Threshold</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='bcorp_certified_latest_tableau' name='federated.08qekmk1t77db116ouqrp1pc2tm0' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select Metric' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Environment&quot;'>
              <calculation class='tableau' formula='&quot;Environment&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.08qekmk1t77db116ouqrp1pc2tm0'>
            <column caption='Certification Age Group' datatype='string' name='[Calculation_2606989965500418]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [years_since_first_certification] &lt; 3 THEN &quot;0-2 years&quot;&#13;&#10;ELSEIF [years_since_first_certification] &lt; 6 THEN &quot;3-5 years&quot;&#13;&#10;ELSEIF [years_since_first_certification] &lt; 10 THEN &quot;6-9 years&quot;&#13;&#10;ELSE &quot;10+ years&quot;&#13;&#10;END' />
            </column>
            <column caption='Score Above Threshold' datatype='real' name='[Calculation_2606989966938115]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[overall_score] - 80' />
            </column>
            <column caption='Selected Metric Value' datatype='real' name='[Calculation_2606989969367045]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;Community&quot; THEN [impact_area_community]&#13;&#10;WHEN &quot;Customers&quot; THEN [impact_area_customers]&#13;&#10;WHEN &quot;Environment&quot; THEN [impact_area_environment]&#13;&#10;WHEN &quot;Governance&quot; THEN [impact_area_governance]&#13;&#10;WHEN &quot;Workers&quot; THEN [impact_area_workers]&#13;&#10;END' />
            </column>
            <column-instance column='[company_id]' derivation='Attribute' name='[attr:company_id:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_2606989966938115]' derivation='Avg' name='[avg:Calculation_2606989966938115:qk]' pivot='key' type='quantitative' />
            <column caption='Company Id' datatype='string' name='[company_id]' role='dimension' type='nominal' />
            <column caption='Company Name' datatype='string' name='[company_name]' role='dimension' type='nominal' />
            <column caption='Country' datatype='string' name='[country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column-instance column='[company_id]' derivation='CountD' name='[ctd:company_id:qk]' pivot='key' type='quantitative' />
            <column caption='Community' datatype='integer' name='[impact_area_community]' role='measure' type='quantitative' />
            <column caption='Customers' datatype='real' name='[impact_area_customers]' role='measure' type='quantitative' />
            <column caption='Environment' datatype='real' name='[impact_area_environment]' role='measure' type='quantitative' />
            <column caption='Governance' datatype='real' name='[impact_area_governance]' role='measure' type='quantitative' />
            <column caption='Workers' datatype='real' name='[impact_area_workers]' role='measure' type='quantitative' />
            <column caption='Industry Category' datatype='string' name='[industry_category]' role='dimension' type='nominal' />
            <column-instance column='[industry_category]' derivation='None' name='[none:industry_category:nk]' pivot='key' type='nominal' />
            <column caption='Overall Score' datatype='real' name='[overall_score]' role='measure' type='quantitative' />
            <column caption='Years Since First Certification' datatype='real' name='[years_since_first_certification]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.08qekmk1t77db116ouqrp1pc2tm0].[Action (Certification Age Group)]'>
            <groupfilter function='level-members' level='[Calculation_2606989965500418]' user:ui-action-filter='[Action3_333A836DD81F4D93B6138CCD9CDA2D5D]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.08qekmk1t77db116ouqrp1pc2tm0].[Action (Company Name,Country)]'>
            <groupfilter function='crossjoin' user:ui-action-filter='[Action2_ACC60E9E011C469EA7E3204E9FC8313B]' user:ui-enumeration='all' user:ui-marker='enumerate'>
              <groupfilter function='level-members' level='[company_name]' />
              <groupfilter function='level-members' level='[country]' />
            </groupfilter>
          </filter>
          <filter class='categorical' column='[federated.08qekmk1t77db116ouqrp1pc2tm0].[Action (Industry Category)]'>
            <groupfilter function='level-members' level='[industry_category]' user:ui-action-filter='[Action4_3D322C451830468E9D43E64B537D105D]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.08qekmk1t77db116ouqrp1pc2tm0].[attr:company_id:nk]'>
            <groupfilter function='level-members' level='[attr:company_id:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.08qekmk1t77db116ouqrp1pc2tm0].[none:industry_category:nk]'>
            <groupfilter count='10' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='AVG([Calculation_2606989969367045])' function='order' user:ui-marker='order'>
                <groupfilter function='level-members' level='[none:industry_category:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
              </groupfilter>
            </groupfilter>
          </filter>
          <alphabetic-sort column='[federated.08qekmk1t77db116ouqrp1pc2tm0].[none:industry_category:nk]' direction='ASC' />
          <slices>
